---
import { Image } from "astro:assets";
import { ExternalLink } from "lucide-preact";

// Import company icons
import aimIcon from "@/assets/logos/aim.png";
import fusionIcon from "@/assets/logos/fusion.jpg";

// Work experience data
const workExperience = [
	{
		company: "Aim AI",
		role: "Founding Engineer",
		period: "Jan 2024 - Apr 2026",
		description:
			"Built a voice AI platform for phone-based conversational agents, including Python/FastAPI services handling 1M+ calls daily, Next.js dashboards, and Dockerized GCP deployments.",
		link: "https://www.aimnow.ai",
		icon: aimIcon,
	},
	{
		company: "Fusion XYZ",
		role: "Full-Stack Engineer",
		period: "Jul 2022 - Sep 2022",
		description:
			"Built HiddenGem, an NFT analytics platform with real-time floor prices, trading volumes, and on-chain data aggregation from Ethereum marketplaces.",
		link: "https://web.archive.org/web/20230329031706/https://www.fusion.xyz/",
		icon: fusionIcon,
	},
];
---

<div class="space-y-8">
  <h2 class="text-2xl font-bold">Work</h2>
  <ul class="space-y-3">
    {
      workExperience.map((job) => (
        <li class="flex items-start gap-3">
          <div class="shrink-0 w-10 h-10 rounded-lg overflow-hidden">
            {job.icon ? (
              <Image
                src={job.icon}
                alt={`${job.company} logo`}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full bg-muted flex items-center justify-center text-sm font-medium">
                {job.company.charAt(0)}
              </div>
            )}
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex items-center justify-between gap-4">
              <span class="font-medium text-base">{job.company}</span>
              {job.link && (
                <a
                  href={job.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs text-muted-foreground hover:underline underline-offset-2 shrink-0 flex items-center gap-1"
                >
                  {job.link.includes("web.archive.org")
                    ? (() => {
                        const match = job.link.match(
                          /\/https?:\/\/www\.([^\/]+)/
                        );
                        return match ? `${match[1]} (archived)` : "Archive";
                      })()
                    : job.link.replace(/^https?:\/\/(www\.)?/, "")}
                  <ExternalLink class="h-3 w-3" />
                </a>
              )}
            </div>
            <div class="text-sm mt-0.5">
              <div>
                {job.role} · {job.period}
              </div>
            </div>
            {job.description && (
              <p class="text-xs text-muted-foreground mt-0.5">
                {job.description}
              </p>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</div>
