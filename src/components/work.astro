---
import { Image } from "astro:assets";
import { ExternalLink } from "lucide-preact";

// Import company icons
import aimIcon from "@/assets/logos/aim.png";
import fusionIcon from "@/assets/logos/fusion.jpg";

// Work experience data
const workExperience = [
	{
		company: "Aim AI",
		role: "Founding Engineer",
		period: "Jan 2024 - Apr 2026",
		description:
			"Helped scale Aim's voice agent platform from pre-revenue to about $8M ARR and 1M daily calls, working across the voice agent runtime, dashboard, public API, agent configuration, outbound campaigns, call review, analytics, evals, dashboard-configured agent tools, and GCP deployments.",
		link: "https://www.aimnow.ai",
		icon: aimIcon,
	},
	{
		company: "Fusion XYZ",
		role: "Full-Stack Engineer",
		period: "Jul 2022 - Sep 2022",
		description:
			"Built HiddenGem, a Next.js NFT analytics dashboard for real-time floor prices, trading volume, trending collections, and wallet insights, with Ethereum event ingestion for sales, transfers, and marketplace data.",
		link: "https://web.archive.org/web/20230329031706/https://www.fusion.xyz/",
		icon: fusionIcon,
	},
];
---

<div class="space-y-8">
  <h2 class="text-2xl font-bold">Work</h2>
  <ul class="space-y-3">
    {
      workExperience.map((job) => (
        <li class="flex items-start gap-3">
          <div class="shrink-0 w-10 h-10 rounded-lg overflow-hidden">
            {job.icon ? (
              <Image
                src={job.icon}
                alt={`${job.company} logo`}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full bg-muted flex items-center justify-center text-sm font-medium">
                {job.company.charAt(0)}
              </div>
            )}
          </div>
          <div class="min-w-0 flex-1">
            <div class="flex min-w-0 items-center justify-between gap-4">
              <span class="min-w-0 truncate font-medium text-base">
                {job.company}
              </span>
              {job.link && (
                <a
                  href={job.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="flex min-w-0 max-w-[55%] shrink items-center gap-1 overflow-hidden text-ellipsis whitespace-nowrap text-xs text-muted-foreground underline-offset-2 hover:underline sm:max-w-none"
                >
                  <span class="min-w-0 truncate">
                    {job.link.includes("web.archive.org")
                      ? (() => {
                          const match = job.link.match(
                            /\/https?:\/\/www\.([^\/]+)/
                          );
                          return match ? `${match[1]} (archived)` : "Archive";
                        })()
                      : job.link.replace(/^https?:\/\/(www\.)?/, "")}
                  </span>
                  <ExternalLink class="h-3 w-3 shrink-0" />
                </a>
              )}
            </div>
            <div class="text-sm mt-0.5">
              <div>
                {job.role} · {job.period}
              </div>
            </div>
            {job.description && (
              <p class="text-xs text-muted-foreground mt-0.5">
                {job.description}
              </p>
            )}
          </div>
        </li>
      ))
    }
  </ul>
</div>
